{
  "dxt_version": "0.2",
  "name": "anthale-mcp",
  "version": "0.0.1",
  "description": "The official MCP Server for the Anthale API",
  "author": {
    "name": "Anthale"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stainless-sdks/anthale-typescript.git"
  },
  "homepage": "https://github.com/stainless-sdks/anthale-typescript/tree/main/packages/mcp-server#readme",
  "documentation": "https://anthale.com/support",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "ANTHALE_API_KEY": "${user_config.ANTHALE_API_KEY}"
      }
    }
  },
  "user_config": {
    "ANTHALE_API_KEY": {
      "title": "api_key",
      "description": "Send an organization API key in the `Authorization` header as `Bearer <api_key>`.",
      "required": true,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": ["api"]
}
